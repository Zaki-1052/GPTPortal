  "scripts": {
    "test": "node scripts/smoke-test.js",
    "start": "node server.js"
  },
  "keywords": [
    "llm",
    "openai",
    "anthropic",
    "claude",
    "gemini",
    "chatbot",
    "openrouter",
    "ollama",
    "express",
    "self-hosted"
  ],
  "author": "Zakir Alibhai",
  "license": "MIT",
