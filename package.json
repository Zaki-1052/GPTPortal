    "axios": "^1.7.4",
    "basic-auth": "^2.0.1",
    "body-parser": "^1.20.2",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.19.2",
    "express-basic-auth": "^1.2.1",
    "express-rate-limit": "^7.4.1",
    "express-session": "^1.18.2",
    "fs": "^0.0.1-security",
    "image-downloader": "^4.3.0",
    "js-tiktoken": "^1.0.20",
    "marked": "^12.0.1",
    "marked-katex-extension": "^5.1.4",
